# Claude Code Mobile Backend Configuration

# Your NVIDIA/Claude API keys (reuse from your existing setup)
OPENROUTER_API_KEY=your_openrouter_key_here
NVIDIA_NIM_API_KEY=your_nvidia_key_here

# Custom API key for iOS app authentication
# Change this to a secure random token!
MOBILE_API_KEY=change_this_to_a_secure_random_token

# Server Configuration
PORT=8082
HOST=0.0.0.0

# Claude Code Integration
# Path to your existing Claude Code directory
CLAUDE_CODE_DIR=/Users/olegha27/free-claude-code

# Path restrictions for security (optional)
# Allowed directories for file operations
#ALLOWED_PATHS=/Users/olegha27/projects:/Users/olegha27/code

# Feature flags
DISABLE_COMMAND_EXECUTION=false
DISABLE_FILE_WRITE=false
MAX_FILE_SIZE_MB=10
